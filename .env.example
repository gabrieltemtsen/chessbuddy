# ─── ChessBuddy Environment Variables ─────────────────────────────────────────
#
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.

# ── ChessBuddyOrg (Circles Organisation Avatar) ────────────────────────────────
#
# This is the Circles Organisation Avatar that acts as the escrow wallet.
# Players stake 1 CRC to this address; the server pays winnings from it.
#
# Your ChessBuddyOrg address (already created):
NEXT_PUBLIC_ADMIN_WALLET_ADDRESS=0x9aCa34983D694e07ce0369a74F63094C989FDf2c

# Private key of the Safe OWNER that controls the org above.
# Used server-side to sign payout transactions.  NEVER expose to the browser.
# This is the private key of YOUR personal wallet that owns the Gnosis Safe.
ADMIN_WALLET_PRIVATE_KEY=0xYOUR_SAFE_OWNER_PRIVATE_KEY

# ── Feature Flags ──────────────────────────────────────────────────────────────
# Set to "false" to skip CRC staking during local development / testing.
# When false, all matches (including Medium/Hard AI) are treated as free.
NEXT_PUBLIC_STAKING_ENABLED=true

# ── Convex (database) ──────────────────────────────────────────────────────────
# Run `npx convex dev` once — it will create a project at dashboard.convex.dev
# and print the URL. Paste it here. The NEXT_PUBLIC_ copy is used by the browser.
CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# ── Circles RPC (optional override) ───────────────────────────────────────────
# Default: https://rpc.aboutcircles.com  (Gnosis Chain mainnet)
# CIRCLES_RPC_URL=https://rpc.aboutcircles.com

# ── Smart-contract escrow (optional — replaces direct CRC transfers) ───────────
#
# Deploy chessbuddy-contracts first:
#   cd ../chessbuddy-contracts
#   cp .env.example .env && fill it in
#   npm install && npx hardhat run scripts/deploy.ts --network gnosis
#
# Then paste the deployed address here. When set, the payout route uses the
# ChessBuddyEscrow contract instead of the Circles SDK direct-transfer path.
# Leave blank (or omit) to keep the original Circles SDK payout flow.
CHESSBUDDY_ESCROW_ADDRESS=

# Gnosis Chain RPC for contract calls (default: public endpoint)
GNOSIS_RPC_URL=https://rpc.gnosischain.com

# ── Next.js ────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL=https://chessbuddy.vercel.app
