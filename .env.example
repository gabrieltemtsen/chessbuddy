# ─── ChessBuddy Environment Variables ─────────────────────────────────────────
#
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
#
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser.
# All others are server-side only.

# ── Admin Wallet ───────────────────────────────────────────────────────────────
# The address that receives staked CRC and distributes payouts.
# This should be a Circles-registered wallet on Gnosis Chain.
NEXT_PUBLIC_ADMIN_WALLET_ADDRESS=0xYOUR_ADMIN_WALLET_ADDRESS

# Private key of the admin wallet (server-side only, NEVER expose to browser).
# Used to sign payout transactions automatically.
# If left empty, payouts are queued as "pending_manual" and must be sent manually.
ADMIN_WALLET_PRIVATE_KEY=0xYOUR_ADMIN_WALLET_PRIVATE_KEY

# ── Feature Flags ──────────────────────────────────────────────────────────────
# Set to "false" to disable CRC staking (useful for development / testnet).
# When false, all matches are treated as free.
NEXT_PUBLIC_STAKING_ENABLED=true

# ── Circles RPC (optional override) ───────────────────────────────────────────
# Default is https://rpc.aboutcircles.com (Gnosis Chain mainnet).
# Only change this if you are running a custom RPC node.
# CIRCLES_RPC_URL=https://rpc.aboutcircles.com

# ── Next.js ────────────────────────────────────────────────────────────────────
# Optional: set to your production domain for OG tags
# NEXT_PUBLIC_APP_URL=https://chessbuddy.vercel.app
